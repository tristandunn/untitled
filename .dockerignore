# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for
# more about ignoring files.

# Ignore bundler configuration.
/.bundle

# Ignore Docker-related files.
/.dockerignore
/Dockerfile*

# Ignore all environment files.
/.env*

# Ignore git directory and files.
/.git/
/.gitattributes
/.gitignore

# Ignore GitHub files.
/.github

# Ignore Ruby-related files.
/.rubocop.yml
/.ruby-lsp/

# Ignore any asset builds.
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore all default key files.
/config/master.key
/config/credentials/*.key

# Ignore all logs and temporary files.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore any development and test files.
/node_modules
/spec
/.yarn
.erb-lint.yml
.stylelintignore
.stylelintrc.json
.yarnrc.yml
Procfile.dev
README.md
babel.config.cjs
eslint.config.cjs
package.json
yarn.lock

# Ignore any pre-compiled assets.
/public/assets

# Ignore any SQLite databases.
/storage/*
!/storage/.keep

# Ignore PID files.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage for uploaded files in development.
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep
